# Copia in `.env.local` e compila i valori. Non committare segreti.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (OCR)
OPENAI_API_KEY=

# Resend (email)
RESEND_API_KEY=

# Cron
CRON_SECRET=

# IMAP globale (opzionale se config per sede nel DB)
# IMAP_HOST=
# IMAP_PORT=993
# IMAP_USER=
# IMAP_PASSWORD=

# Opzionale: PIN (1–12 caratteri) richiesto sulla schermata login admin prima di email/password.
# Se assente o vuoto, il gate non è attivo. Vedi `src/app/api/admin-login-gate/route.ts`.
# ADMIN_LOGIN_GATE_PIN=
