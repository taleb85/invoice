# Copia in `.env.local` e compila i valori. Non committare segreti.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google AI — Gemini (OCR / estrazione documenti)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Resend (email)
RESEND_API_KEY=

# Cron
CRON_SECRET=

# Rekki — ricerca fornitore da P.IVA (`POST /api/fornitore-rekki`, server Next.js).
# Dev: `.env.local` in root progetto. Prod: variabili d’ambiente del deploy (es. Vercel), non Supabase salvo Edge dedicata.
# REKKI_API_KEY=
# URL con placeholder {vat} (solo cifre), es. https://api.example.com/v1/suppliers?vat={vat}
# REKKI_SUPPLIERS_SEARCH_URL=

# IMAP globale (opzionale se config per sede nel DB)
# IMAP_HOST=
# IMAP_PORT=993
# IMAP_USER=
# IMAP_PASSWORD=

# Opzionale: PIN (1–12 caratteri) richiesto sulla schermata login admin prima di email/password.
# Se assente o vuoto, il gate non è attivo. Vedi `src/app/api/admin-login-gate/route.ts`.
# ADMIN_LOGIN_GATE_PIN=
