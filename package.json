{
  "name": "invoice",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=8192' next dev --turbo",
    "dev:webpack": "NODE_OPTIONS='--max-old-space-size=8192' next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "verify": "npm run lint && npm run build",
    "deploy": "npm run build && bash scripts/vercel-deploy-nogit.sh --no-wait",
    "deploy:sync": "npm run build && bash scripts/vercel-deploy-nogit.sh",
    "deploy:debug": "npm run build && bash scripts/vercel-deploy-nogit.sh --debug",
    "vercel:prod": "bash scripts/vercel-deploy-nogit.sh --no-wait",
    "db:apply-migrations": "node scripts/apply-supabase-migrations.mjs",
    "db:apply-migrations:dry": "node scripts/apply-supabase-migrations.mjs --dry-run",
    "db:reset-email-scan": "node scripts/reset-email-scan-state.mjs"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@google/generative-ai": "^0.24.1",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.102.1",
    "date-fns": "^4.1.0",
    "googleapis": "^171.4.0",
    "imapflow": "^1.2.18",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "mailparser": "^3.9.6",
    "next": "16.2.2",
    "open": "^11.0.0",
    "openai": "^6.33.0",
    "papaparse": "^5.5.3",
    "pdf-parse": "^2.4.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.10.0",
    "sharp": "^0.33.5",
    "swr": "^2.4.1",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "canvas": "^3.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "postgres": "^3.4.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vercel": "^50.44.0"
  }
}
