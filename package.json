{
  "name": "invoice",
  "version": "0.1.208",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=8192' next dev --turbopack",
    "dev:clean": "rm -rf .next && NODE_OPTIONS='--max-old-space-size=8192' next dev --turbopack",
    "dev:webpack": "NODE_OPTIONS='--max-old-space-size=8192' next dev --webpack",
    "dev:restart": "node scripts/kill-port.mjs 3000 && npm run dev",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint",
    "verify": "npm run lint && npm run build",
    "version:bump": "npm version patch --no-git-tag-version",
    "deploy": "npm run version:bump && npm run build && bash scripts/vercel-deploy-nogit.sh --no-wait",
    "deploy:sync": "npm run version:bump && npm run build && bash scripts/vercel-deploy-nogit.sh",
    "deploy:debug": "npm run version:bump && npm run build && bash scripts/vercel-deploy-nogit.sh --debug",
    "vercel:prod": "npm run version:bump && bash scripts/vercel-deploy-nogit.sh --no-wait",
    "db:apply-migrations": "node scripts/apply-supabase-migrations.mjs",
    "db:apply-migrations:dry": "node scripts/apply-supabase-migrations.mjs --dry-run",
    "db:reset-email-scan": "node scripts/reset-email-scan-state.mjs",
    "process:sync": "node scripts/run-cron-local.mjs /api/cron/sync-emails",
    "process:auto-invoices": "node scripts/run-cron-local.mjs /api/cron/auto-process-invoices",
    "process:rekki": "node scripts/run-cron-local.mjs /api/cron/rekki-auto-poll",
    "process:backup": "node scripts/run-cron-local.mjs /api/cron/backup",
    "process": "node scripts/run-cron-local.mjs",
    "reprocess:statements": "REPROCESS_STMT_ALL=1 vitest run src/lib/__tests__/reprocess-statement-checks-all.integration.test.ts",
    "ai:analyze": "node scripts/ai-analyze.mjs",
    "audit:ocr": "node scripts/audit-processed-ocr.mjs",
    "audit:ocr:fatture": "node scripts/audit-processed-ocr.mjs --table=fatture",
    "audit:ocr:bolle": "node scripts/audit-processed-ocr.mjs --table=bolle",
    "audit:full": "node scripts/audit-and-fix-all.mjs",
    "audit:full:ai": "node scripts/audit-and-fix-all.mjs --with-ai",
    "audit:full:dry": "node scripts/audit-and-fix-all.mjs --dry-run",
    "audit:cleanup": "node scripts/audit-and-fix-all.mjs --phase=cleanup",
    "audit:cleanup:apply": "node scripts/audit-and-fix-all.mjs --phase=cleanup --cleanup-apply",
    "audit:cleanup:co": "node scripts/audit-and-fix-all.mjs --phase=cleanup_conferme_ordine",
    "audit:cleanup:co:apply": "node scripts/audit-and-fix-all.mjs --phase=cleanup_conferme_ordine --cleanup-apply",
    "fix:audit": "node scripts/fix-audit-anomalies.mjs",
    "fix:audit:dry": "node scripts/fix-audit-anomalies.mjs --dry-run",
    "fix:eden-springs": "node scripts/fix-eden-springs-duplicates.mjs",
    "fix:eden-springs:dry": "node scripts/fix-eden-springs-duplicates.mjs --dry-run",
    "fix:eden-springs:statements": "node scripts/requeue-eden-springs-statements.mjs",
    "fix:eden-springs:statements:dry": "node scripts/requeue-eden-springs-statements.mjs --dry-run",
    "audit:listino-qty": "node scripts/audit-listino-qty-prices.mjs",
    "audit:listino-qty:apply": "node scripts/audit-listino-qty-prices.mjs --apply",
    "repair:listino-prices": "node scripts/repair-listino-prices.mjs",
    "repair:listino-prices:apply": "node scripts/repair-listino-prices.mjs --apply"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@google/generative-ai": "^0.24.1",
    "@radix-ui/react-switch": "^1.2.6",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.102.1",
    "date-fns": "^4.1.0",
    "googleapis": "^171.4.0",
    "imapflow": "^1.2.18",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "mailparser": "^3.9.6",
    "next": "16.2.2",
    "open": "^11.0.0",
    "papaparse": "^5.5.3",
    "pdf-parse": "^2.4.5",
    "pino": "^10.3.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "resend": "^6.10.0",
    "swr": "^2.4.1",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.1.5",
    "canvas": "^3.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "postgres": "^3.4.9",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vercel": "53.3.1",
    "vitest": "^4.1.5"
  }
}
